# Sanitizer environment variables

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log directory (default: logs/)
# LOG_DIR=logs

# Show tracebacks in the UI on errors (set to 1 or true to enable)
# Also enabled automatically when LOG_LEVEL=DEBUG
# SANITIZER_DEBUG=false

# Resource limits (see Step 5 — all optional, sensible defaults apply)
# SANITIZER_MAX_DEPTH=10
# SANITIZER_MAX_FILES=500
# SANITIZER_DISCOVERY_TIMEOUT=60
# SANITIZER_MAX_FILE_MB=500
# SANITIZER_MAX_TOTAL_MB=2000
# SANITIZER_MAX_OUTPUT_ROWS=5000000
